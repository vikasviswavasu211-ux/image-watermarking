{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "resolveJsonModule": true
  },
  "include": ["server.ts", "api/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
