{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "noEmit": false,
    "outDir": ".",
    "strict": false,
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
